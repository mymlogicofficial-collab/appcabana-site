<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <h1>Your Sovereign<br>App Store</h1>
      <p>Browse, share, and install desktop, web, and mobile applications directly to your local file system. No middleman, no cloud lock-in &mdash; full control over your software.</p>
      <div class="hero-actions">
        <a href="/browse" class="btn btn-primary btn-lg">Browse Apps</a>
        <a href="/submit" class="btn btn-outline btn-lg">Submit Your App</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value"><%= stats.total_apps %></span>
          <span class="stat-label">Apps Listed</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= Number(stats.total_downloads).toLocaleString() %></span>
          <span class="stat-label">Total Downloads</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= stats.total_developers %></span>
          <span class="stat-label">Developers</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>How It Works</h2>
      <p>Direct-to-disk app hosting powered by the File System Access API</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <h3>Save to Your Vault</h3>
        <p>Use the File System Access API to save apps directly to your chosen directory. Pick your folder, control your storage.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <h3>Local File System Access</h3>
        <p>Full read/write access to your local directories. Organize, manage, and launch apps without cloud dependencies.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Sovereign Storage</h3>
        <p>Your 1TB vault stays on your machine. No subscriptions, no bandwidth limits, no third-party access to your software library.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="container">
    <div class="section-header">
      <h2>Browse by Category</h2>
      <p>Find the perfect app for your needs</p>
    </div>
    <div class="categories-grid">
      <% categories.forEach(cat => { %>
        <a href="/browse?category=<%= cat.slug %>" class="category-card">
          <div class="category-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <% if (cat.icon === 'briefcase') { %><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
              <% } else if (cat.icon === 'code') { %><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              <% } else if (cat.icon === 'palette') { %><circle cx="13.5" cy="6.5" r="0.5"/><circle cx="17.5" cy="10.5" r="0.5"/><circle cx="8.5" cy="7.5" r="0.5"/><circle cx="6.5" cy="12.5" r="0.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
              <% } else if (cat.icon === 'play-circle') { %><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
              <% } else if (cat.icon === 'wrench') { %><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              <% } else if (cat.icon === 'message-circle') { %><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              <% } else if (cat.icon === 'shield') { %><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <% } else if (cat.icon === 'book-open') { %><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              <% } else if (cat.icon === 'gamepad-2') { %><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><line x1="15" y1="13" x2="15.01" y2="13"/><line x1="18" y1="11" x2="18.01" y2="11"/><rect x="2" y="6" width="20" height="12" rx="2"/>
              <% } else if (cat.icon === 'building-2') { %><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>
              <% } else { %><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <% } %>
            </svg>
          </div>
          <span><%= cat.name %></span>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<% if (apps.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Featured Apps</h2>
      <a href="/browse" class="btn btn-outline btn-sm">View All</a>
    </div>
    <div class="apps-grid">
      <% apps.forEach(app => { %>
        <%- include('../partials/app-card', { app }) %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section cta-section">
  <div class="container">
    <div class="cta-content">
      <h2>Ready to Share Your App?</h2>
      <p>Join the platform and make your application available to thousands of users. Desktop, web, or mobile &mdash; direct downloads, no restrictions.</p>
      <a href="/submit" class="btn btn-primary btn-lg">Submit Your App</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
