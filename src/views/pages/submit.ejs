<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="section">
  <div class="container">
    <div class="submit-page">
      <h1>Submit Your App</h1>
      <p>Share your desktop, web, or mobile application with the The App Cabana community</p>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/submit" enctype="multipart/form-data" class="submit-form">
        <div class="form-row">
          <div class="form-group">
            <label>App Name *</label>
            <input type="text" name="name" required class="input" placeholder="My Amazing App">
          </div>
          <div class="form-group">
            <label>Version</label>
            <input type="text" name="version" class="input" placeholder="1.0.0">
          </div>
        </div>
        <div class="form-group">
          <label>Short Description *</label>
          <input type="text" name="description" required class="input" placeholder="A brief description of your app" maxlength="300">
        </div>
        <div class="form-group">
          <label>Full Description</label>
          <textarea name="long_description" class="input" rows="6" placeholder="Detailed description, features, changelog..."></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Category</label>
            <select name="category_id" class="input">
              <option value="">Select a category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Platform</label>
            <select name="platform" class="input">
              <option value="Windows">Windows</option>
              <option value="macOS">macOS</option>
              <option value="Linux">Linux</option>
              <option value="Cross-platform">Cross-platform (Desktop)</option>
              <option value="Web">Web App</option>
              <option value="iOS">iOS</option>
              <option value="Android">Android</option>
              <option value="Mobile">Mobile (iOS & Android)</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>License</label>
            <select name="license_type" class="input">
              <option value="Free">Free</option>
              <option value="Open Source">Open Source</option>
              <option value="Freemium">Freemium</option>
              <option value="Paid">Paid</option>
              <option value="Trial">Trial</option>
            </select>
          </div>
          <div class="form-group">
            <label>Min OS Version</label>
            <input type="text" name="min_os_version" class="input" placeholder="Windows 10, macOS 12...">
          </div>
        </div>
        <div class="form-group">
          <label>App Icon</label>
          <input type="file" name="icon" accept="image/*" class="input-file">
          <small>Recommended: 256x256 PNG. Max 5MB.</small>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Website URL</label>
            <input type="url" name="website_url" class="input" placeholder="https://myapp.com">
          </div>
          <div class="form-group">
            <label>Source Code URL</label>
            <input type="url" name="source_url" class="input" placeholder="https://github.com/...">
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-lg">Submit App</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
